# mordomo-brain environment
# Copy to .env and fill in values before running.

# NATS
NATS_URL=nats://mordomo-nats:4222

# Bifrost gateway (infra)
BIFROST_URL=http://llm-gateway:8080
BIFROST_API_KEY=
EMBEDDING_MODEL=gemini/text-embedding-004

# Redis (db1 = mordomo-general)
REDIS_URL=redis://mordomo-redis:6379/1

# Qdrant (RAG)
QDRANT_URL=http://mordomo-qdrant:6333
QDRANT_COLLECTION=mordomo_conversations
RAG_ENABLED=true
QDRANT_VECTOR_SIZE=768

# Tier semantic fallback and policy
TIER_FALLBACK=simple
TIER_STRICT_MODE=false
TIER_CACHE_TTL=300

# Groq — fallback direto quando o gateway principal falhar
# Obtenha em: https://console.groq.com
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Context settings
CONTEXT_MAX_MESSAGES=12
CONTEXT_TTL_SECONDS=1800
CONTEXT_SUMMARIZE_KEEP=4
