# mordomo-brain environment
# Copy to .env and fill in values before running.

# NATS
NATS_URL=nats://mordomo-nats:4222

# LiteLLM gateway (infra — já configurado com as API keys)
LITELLM_URL=http://mordomo-litellm:4000

# Redis (db1 = mordomo-general)
REDIS_URL=redis://mordomo-redis:6379/1

# Qdrant (RAG)
QDRANT_URL=http://mordomo-qdrant:6333
QDRANT_COLLECTION=mordomo_conversations
RAG_ENABLED=true

# LLM virtual model names (configurados no LiteLLM gateway)
MODEL_SIMPLE=mordomo-simple
MODEL_COMPLEX=mordomo-complex
MODEL_STAKES=mordomo-stakes

# Context settings
CONTEXT_MAX_MESSAGES=12
CONTEXT_TTL_SECONDS=1800
